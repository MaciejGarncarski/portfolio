{
  "name": "portfolio",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint --fix --max-warnings=0 \"src/**/*.{js,ts,jsx,tsx,astro}\"",
    "format": "prettier --write  \"**/*.{js,jsx,ts,tsx,md,mdx,astro}\"",
    "lint-format": "pnpm format && pnpm lint",
    "prepare": "husky install"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,astro}": "pnpm lint",
    "*.{js,jsx,ts,tsx,md,mdx,astro}": "pnpm format --cache"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.1.1",
    "@astrojs/tailwind": "^5.1.0",
    "@astrojs/ts-plugin": "^1.5.3",
    "@fontsource/montserrat": "^5.0.16",
    "@iconify-json/openmoji": "^1.1.46",
    "@iconify-json/ph": "^1.1.11",
    "astro": "^4.4.15",
    "astro-compress": "^2.2.10",
    "astro-icon": "^1.1.0",
    "clsx": "^2.1.0",
    "tailwindcss": "^3.4.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.4.0",
    "@commitlint/config-conventional": "^18.4.0",
    "@tailwindcss/typography": "^0.5.10",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "eslint": "^8.53.0",
    "eslint-plugin-astro": "^0.29.1",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-simple-import-sort": "^10.0.0",
    "husky": "^8.0.3",
    "lint-staged": "^15.0.2",
    "prettier": "^3.0.3",
    "prettier-plugin-astro": "^0.13.0",
    "prettier-plugin-tailwindcss": "^0.5.12",
    "typescript": "^5.4.2"
  }
}
