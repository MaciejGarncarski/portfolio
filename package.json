{
  "name": "portfolio",
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@9.4.0",
  "scripts": {
    "dev": "astro dev",
    "start": "astro preview",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint --fix .",
    "format": "prettier --write  \"**/*.{js,jsx,ts,tsx,md,mdx,astro}\"",
    "lint-format": "pnpm format && pnpm lint",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,astro}": "pnpm lint",
    "*.{js,jsx,ts,tsx,md,mdx,astro}": "pnpm format --cache"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.2.1",
    "@astrojs/ts-plugin": "^1.10.4",
    "@fontsource/poppins": "^5.1.0",
    "@iconify-json/openmoji": "^1.2.4",
    "@iconify-json/ph": "^1.2.1",
    "@tailwindcss/postcss": "4.0.0-alpha.17",
    "@tailwindcss/typography": "^0.5.15",
    "astro": "5.0.0-beta.6",
    "astro-compress": "^2.3.5",
    "astro-icon": "^1.1.1",
    "clsx": "^2.1.1",
    "sharp": "^0.33.5",
    "tailwindcss": "4.0.0-alpha.17"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@eslint/compat": "^1.2.2",
    "@eslint/js": "^9.13.0",
    "@types/eslint__js": "^8.42.3",
    "@types/pg": "^8.11.10",
    "eslint": "^9.13.0",
    "eslint-plugin-astro": "^1.3.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.12.2"
  }
}
