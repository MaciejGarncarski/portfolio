{
  "name": "portfolio",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint --fix --max-warnings=0 \"src/**/*.{js,ts,jsx,tsx,astro}\"",
    "format": "prettier --write  \"**/*.{js,jsx,ts,tsx,md,mdx,astro}\"",
    "lint-format": "yarn format && yarn lint",
    "prepare": "husky install"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,astro}": "yarn lint",
    "*.{js,jsx,ts,tsx,md,mdx,astro}": "yarn format --cache"
  },
  "dependencies": {
    "@astrojs/image": "^0.16.8",
    "@astrojs/react": "^2.1.3",
    "@astrojs/sitemap": "^1.3.1",
    "@astrojs/tailwind": "^3.1.2",
    "@astrojs/ts-plugin": "^1.0.6",
    "@fontsource/montserrat": "^4.5.14",
    "astro": "^2.6.0",
    "astro-icon": "^0.8.0",
    "clsx": "^1.2.1",
    "tailwindcss": "^3.0.24"
  },
  "devDependencies": {
    "@commitlint/cli": "^17.6.3",
    "@commitlint/config-conventional": "^17.6.3",
    "@typescript-eslint/eslint-plugin": "^5.59.5",
    "@typescript-eslint/parser": "^5.59.2",
    "eslint": "^8.40.0",
    "eslint-plugin-astro": "^0.26.1",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-jsx-a11y": "^6.7.1",
    "eslint-plugin-simple-import-sort": "^10.0.0",
    "husky": "^8.0.0",
    "lint-staged": "^13.2.2",
    "prettier": "^2.8.8",
    "prettier-plugin-astro": "^0.8.0",
    "prettier-plugin-tailwindcss": "^0.2.8"
  }
}
