{
  "name": "portfolio",
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@9.4.0",
  "scripts": {
    "dev": "astro dev",
    "start": "astro preview",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint --fix --max-warnings=0 \"src/**/*.{js,ts,jsx,tsx,astro}\"",
    "format": "prettier --write  \"**/*.{js,jsx,ts,tsx,md,mdx,astro}\"",
    "lint-format": "pnpm format && pnpm lint",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,astro}": "pnpm lint",
    "*.{js,jsx,ts,tsx,md,mdx,astro}": "pnpm format --cache"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.1.5",
    "@astrojs/ts-plugin": "^1.8.0",
    "@fontsource/poppins": "^5.0.14",
    "@iconify-json/openmoji": "^1.1.51",
    "@iconify-json/ph": "^1.1.13",
    "@tailwindcss/postcss": "4.0.0-alpha.17",
    "@tailwindcss/typography": "^0.5.13",
    "astro": "^4.11.5",
    "astro-compress": "^2.2.27",
    "astro-icon": "^1.1.0",
    "clsx": "^2.1.1",
    "sharp": "^0.33.4",
    "tailwindcss": "4.0.0-alpha.17"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "eslint": "^8.53.0",
    "eslint-plugin-astro": "^0.33.1",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-simple-import-sort": "^12.1.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.5",
    "prettier": "^3.2.5",
    "prettier-plugin-astro": "^0.14.0",
    "prettier-plugin-tailwindcss": "^0.6.5",
    "typescript": "^5.4.5"
  }
}
