---
import LanguagePicker from '@components/LanguagePicker.astro';
import Nav from '@components/Nav.astro';

import '@fontsource/montserrat';
import '@styles/tw-base.css';
import { getLangFromUrl } from '../i18n/utils';
import { title } from 'src/utils/ui';

const lang = getLangFromUrl(Astro.url);

export type Props = {
  routes: Record<'en' | 'pl', string>;
  hiddenNav?: boolean;
};

const { routes, hiddenNav } = Astro.props;
---

<!DOCTYPE html>
<html class="bg-waves" lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body
    class="border-2 border-slate-900 px-2 sm:border-layout sm:px-4 lg:border-layout-desktop lg:px-6"
  >
    {!hiddenNav && <Nav />}
    <main
      class="min-h-[70vh] pb-10 lg:mx-auto lg:min-h-[85vh] lg:max-w-6xl lg:pb-20 lg:pt-20"
    >
      <slot />
    </main>
    <footer
      class="-mx-2 mt-0 min-h-[150px] bg-primary p-4 text-white sm:-mx-6 sm:mt-0"
    >
      <LanguagePicker routes={routes} />
    </footer>
  </body>
</html>
