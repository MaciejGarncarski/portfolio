---
import Footer from '@components/Footer.astro';
import Nav from '@components/Nav.astro';
import ScrollUpButton from '@components/ScrollUpButton.astro';

import '@fontsource/montserrat';
import '@styles/tw-base.css';
import { getLangFromUrl } from '../i18n/utils';
import { ViewTransitions } from 'astro:transitions';
import { description, keywords, title } from 'src/utils/seo';

const lang = getLangFromUrl(Astro.url);
---

<!doctype html>
<html class="bg-primary" lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description[lang]} />
    <meta name="keywords" content={keywords} />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/favicons/apple-touch-icon.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href="/favicons/favicon-32x32.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="16x16"
      href="/favicons/favicon-16x16.png"
    />
    <link rel="manifest" href="/site.webmanifest" />
    <link
      rel="mask-icon"
      href="/favicons/safari-pinned-tab.svg"
      color="#1e293b"
    />
    <meta name="msapplication-TileColor" content="#1e293b" />
    <meta name="theme-color" content="#1e293b" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <ViewTransitions />
  </head>
  <body
    class="mb-0 min-h-screen border border-b-0 p-1 border-primary text-primary antialiased dark:text-primary sm:border-layout md:border-layout-desktop md:border-b-0">
    <div class="bg-waves bg-white rounded-md md:rounded-xl p-4">
      <Nav />
      <div
        class="min-h-[70vh] pb-10 md:mx-auto md:min-h-[80vh] md:max-w-lg lg:min-h-[85vh] lg:max-w-3xl md:pb-24 md:pt-16">
        <header data-header transition:animate="fade">
          <slot name="header" />
        </header>
        <main data-main transition:animate="fade">
          <slot name="main" />
        </main>
      </div>
    </div>
    <Footer />
    <ScrollUpButton />
  </body>
</html>
