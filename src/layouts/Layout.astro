---
import Footer from '@components/Footer.astro';
import Nav from '@components/Nav.astro';
import ScrollUpButton from '@components/ScrollUpButton.astro';

import '@fontsource/montserrat';
import '@styles/tw-base.css';
import { getLangFromUrl } from '../i18n/utils';
import { description, keywords, title } from 'src/utils/seo';

const lang = getLangFromUrl(Astro.url);

export type Props = {
  routes: Record<'en' | 'pl', string>;
};

const { routes } = Astro.props;
---

<!DOCTYPE html>
<html class="bg-white bg-waves" lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description[lang]} />
    <meta name="keywords" content={keywords} />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/favicons/apple-touch-icon.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href="/favicons/favicon-32x32.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="16x16"
      href="/favicons/favicon-16x16.png"
    />
    <link rel="manifest" href="/site.webmanifest" />
    <link
      rel="mask-icon"
      href="/favicons/safari-pinned-tab.svg"
      color="#5bbad5"
    />
    <meta name="msapplication-TileColor" content="#da532c" />
    <meta name="theme-color" content="#ffffff" />
    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body
    class="mb-0 border-2 border-b-0 border-primary px-3 text-primary dark:text-primary sm:border-layout sm:px-5 lg:border-layout-desktop lg:border-b-0 lg:px-0">
    <Nav />
    <div
      class="min-h-[70vh] pb-10 md:mx-auto md:min-h-[80vh] md:max-w-lg lg:min-h-[85vh] lg:max-w-4xl lg:pb-24 lg:pt-16">
      <header data-header>
        <slot name="header" />
      </header>
      <main data-main>
        <slot name="main" />
      </main>
    </div>
    <Footer routes={routes} />
    <ScrollUpButton />
  </body>
</html>
