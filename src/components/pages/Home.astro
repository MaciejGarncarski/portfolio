---
import Heading from '@components/Heading.astro';
import HomeLink from '@components/HomeLink.astro';

import Layout from '@layouts/Layout.astro';

import { technologies } from './Home.data';
import { Icon } from 'astro-icon';
import { homeRoute } from 'src/i18n/translations/routes';
import { getLangFromUrl, useTranslations } from 'src/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout routes={homeRoute}>
  <Fragment slot="header">
    <Heading variant="primary" tag="h1">Maciej Garncarski</Heading>
    <h2 class="text-xl text-secondary md:text-2xl lg:mt-2 lg:text-3xl">
      Frontend developer
    </h2>
    <p class="my-4 text-secondary lg:my-6 lg:text-2xl">
      {t('home.description')}
    </p>

    <HomeLink href={t('nav.contact.route')} text={t('home.link-contact')} />
  </Fragment>
  <section slot="main" class="mt-10 flex flex-col gap-2 lg:mt-20 lg:gap-6">
    <div class="col-span-3">
      <Heading variant="secondary" tag="h3">{t('home.tech.heading')}</Heading>
    </div>
    <ul
      class="mb-2 grid grid-cols-3 gap-4 md:max-w-sm md:gap-10 lg:mb-4 lg:max-w-md lg:gap-x-20 lg:gap-y-10">
      {
        technologies.map(({ name, fileName, link }) => {
          return (
            <li class="w-full justify-self-start lg:w-auto">
              <a
                class="flex flex-col items-center justify-center gap-2 border-4 border-primary p-2 ring-primary hover:ring-2 focus:outline-none focus:ring-4 focus:ring-offset-4"
                href={link}
                target="_blank"
                rel="noopener noreferrer">
                <Icon
                  name={`Logos${fileName}`}
                  class="h-16 w-16 lg:h-20 lg:w-20"
                />
                <span class="visually-hidden">{name}</span>
              </a>
            </li>
          );
        })
      }
    </ul>
    <HomeLink href={t('nav.projects.route')} text={t('projects.heading')} />
  </section>
</Layout>
