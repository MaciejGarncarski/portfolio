---
import Heading from '@components/Heading.astro';

import Layout from '@layouts/Layout.astro';

import { getProjectsData } from './Projects.data';
import { Icon } from 'astro-icon';
import { projectsRoute } from 'src/i18n/ui';
import { getLangFromUrl, useTranslations } from 'src/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const projects = getProjectsData(lang);
---

<Layout routes={projectsRoute}>
  <article>
    <header>
      <Heading variant="primary" tag="h1">{t('projects.heading')}</Heading>
    </header>
    <div class="mt-8 flex flex-col gap-20 lg:gap-28 xl:mt-16 2xl:gap-32">
      {
        projects.map(
          ({ description, repo, live, screenshotFileName, title, tags }) => {
            return (
              <article class="flex flex-col gap-4 lg:gap-6">
                <picture>
                  <source
                    type="image/webp"
                    srcset={`/screenshots/webp/${screenshotFileName}.webp`}
                  />
                  <source
                    type="image/png"
                    srcset={`/screenshots/png/${screenshotFileName}.png`}
                  />
                  <img
                    class="min-h-[10rem] w-auto border-2 border-primary lg:min-h-[22rem] lg:max-w-3xl lg:border-4"
                    src={`/screenshots/png/${screenshotFileName}.png`}
                    alt={title}
                    width="305"
                    height="160"
                    loading="lazy"
                  />
                </picture>
                <Heading tag="h2" variant="secondary">
                  {title}
                </Heading>
                <ul class="flex flex-wrap gap-x-3 gap-y-1.5">
                  {tags.map((tag) => (
                    <li class="bg-primary  px-2 py-1 font-semibold text-white lg:px-3">
                      <span>{tag}</span>
                    </li>
                  ))}
                </ul>
                <p class="text-primary lg:max-w-2xl">{description}</p>
                <div class="flex gap-4 lg:gap-8">
                  <a
                    href={live}
                    target="_blank"
                    rel="noreferrer noopener"
                    class="flex items-center gap-2 border-2 border-primary bg-primary px-2 py-1 font-bold text-white">
                    {t('projects.live')}
                    <Icon
                      name="ph:arrow-up-right"
                      class="h-5 w-5 lg:h-6 lg:w-6"
                    />
                  </a>
                  <a
                    href={repo}
                    target="_blank"
                    rel="noreferrer noopener"
                    class="flex items-center gap-2 border-2 border-primary bg-white px-2 py-1 font-bold">
                    {t('projects.repo')}
                    <Icon
                      name="ph:arrow-up-right"
                      class="h-5 w-5 lg:h-6 lg:w-6"
                    />
                  </a>
                </div>
              </article>
            );
          }
        )
      }
    </div>
  </article>
</Layout>
