---
import { Image } from 'astro:assets';

export type Props = {
  image: ImageMetadata;
  title: string;
  priority: boolean;
};

const { image, title, priority } = Astro.props;
---

<Image
  src={image}
  alt={title}
  loading={priority ? 'eager' : 'lazy'}
  class="min-h-[10rem] w-auto border-2 bg-primary border-primary lg:min-h-[22rem] lg:max-w-2xl lg:border-4"
/>
