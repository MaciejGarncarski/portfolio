---
import clsx from 'clsx';

type Tag = 'h1' | 'h2' | 'h3' | 'h4' | 'h5' | 'h6';
type Variant = 'primary' | 'secondary';

export type Props = {
  tag: Tag;
  variant: Variant;
};

const { tag: Tag, variant } = Astro.props;

const variantPrimary =
  'text-4xl md:text-5xl lg:text-6xl text-primary font-black uppercase leading-8 tracking-tight';
const variantSecondary =
  'text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight max-w-xl font-black leading-7';

const headingVariants = {
  primary: variantPrimary,
  secondary: variantSecondary
};
---

<Tag class={clsx('break-words', headingVariants[variant])}>
  <slot />
</Tag>
