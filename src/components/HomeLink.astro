---
import { Icon } from 'astro-icon/components';

export type Props = {
  text: string;
  href: string;
};

const { text, href } = Astro.props;
---

<a
  href={href}
  data-astro-prefetch
  class="inline-flex w-fit items-center gap-2 border-2 border-primary bg-primary px-3 py-1 text-white transition text-sm hover:bg-white hover:text-primary focus:outline-none focus:ring-4 focus:ring-primary focus:ring-offset-4 rounded lg:text-lg">
  <span>
    {text}
  </span>
  <Icon name="ph:arrow-right" class="h-6 w-6 lg:h-6 lg:w-6" />
</a>
